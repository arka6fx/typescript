{
  "compilerOptions": {
    // Bun runs .ts directly — this is only for editor support
    "target": "esnext",
    "module": "nodenext",
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "moduleDetection": "force",
    "types": ["bun-types"]
  },
  "include": ["src/**/*.ts"]
}
